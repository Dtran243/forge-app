{
  "expo": {
    "name": "Forge",
    "slug": "forge",
    "icon": "./assets/icon.png",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "forge",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "ios": {
      "bundleIdentifier": "com.dric.forge",
      "buildNumber": "8",
      "supportsTablet": false,
      "infoPlist": {
        "NSHealthShareUsageDescription": "Forge reads your HRV, sleep, and workout data to calibrate your training program.",
        "NSHealthUpdateUsageDescription": "Forge does not write to Apple Health."
      }
    },
    "plugins": [
      "expo-router",
      [
        "react-native-health",
        {
          "isClinicalDataEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a307fd0a-f247-405d-96d9-00908e67260b"
      }
    }
  }
}
